    </worksheet>
    <worksheet name='ML - Correlation matrix'>
      <table>
        <view>
          <datasources>
            <datasource caption='Feature correlations (ML)' name='federated.ml01_corr' />
          </datasources>
          <datasource-dependencies datasource='federated.ml01_corr'>
            <column datatype='string' name='[Variable_X]' role='dimension' type='nominal' />
            <column datatype='string' name='[Variable_Y]' role='dimension' type='nominal' />
            <column datatype='real' default-format='#0.000' name='[Pearson_r]' role='measure' type='quantitative' />
            <column-instance column='[Variable_X]' derivation='None' name='[none:Variable_X:nk]' pivot='key' type='nominal' />
            <column-instance column='[Variable_Y]' derivation='None' name='[none:Variable_Y:nk]' pivot='key' type='nominal' />
            <column-instance column='[Pearson_r]' derivation='Avg' name='[avg:Pearson_r:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Square' />
            <encodings>
              <color column='[federated.ml01_corr].[avg:Pearson_r:qk]' />
              <text column='[federated.ml01_corr].[avg:Pearson_r:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='false' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.ml01_corr].[none:Variable_Y:nk]</rows>
        <cols>[federated.ml01_corr].[none:Variable_X:nk]</cols>
      </table>
      <simple-id uuid='{B2000001-0000-0000-0000-000000000001}' />
    </worksheet>

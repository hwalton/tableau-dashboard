      <aliases enabled='yes' />
      <column caption='Ave Bedrms' datatype='real' name='[AveBedrms]' role='measure' type='quantitative' />
      <column caption='Ave Occup' datatype='real' name='[AveOccup]' role='measure' type='quantitative' />
      <column caption='Ave Rooms' datatype='real' name='[AveRooms]' role='measure' type='quantitative' />
      <column caption='House Age' datatype='real' name='[HouseAge]' role='measure' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[Latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[Longitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
      <column caption='Med House Val' datatype='real' name='[MedHouseVal]' role='measure' type='quantitative' />
      <column caption='Med Inc' datatype='real' name='[MedInc]' role='measure' type='quantitative' />
      <column caption='california_housing.csv' datatype='table' name='[__tableau_internal_object_id__].[california_housing.csv_4E4DA77C99974D3EA7123D8961467D08]' role='measure' type='quantitative' />
      <column caption='Coastal Flag' datatype='string' name='[Calculation_1001]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Longitude] &lt;= -121 THEN &quot;Coastal&quot; ELSE &quot;Inland&quot; END' />
      </column>
      <column caption='Price-to-Income Ratio' datatype='real' default-format='#,##0.00' name='[Calculation_1002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MedHouseVal] / [MedInc]' />
      </column>
      <column caption='Lat Bin' datatype='real' default-format='#,##0.0' name='[Calculation_1003]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative'>
        <calculation class='tableau' formula='ROUND([Latitude]*5)/5' />
      </column>
      <column caption='Lon Bin' datatype='real' default-format='#,##0.0' name='[Calculation_1004]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative'>
        <calculation class='tableau' formula='ROUND([Longitude]*5)/5' />
      </column>
      <column caption='Region Avg Value' datatype='real' default-format='#,##0.00' name='[Calculation_1005]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_1001] : AVG([MedHouseVal]) }' />
      </column>
      <column caption='Value residual (red = pricier vs coastal / inland avg)' datatype='real' default-format='#,##0.00' name='[Calculation_1006]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MedHouseVal] - [Calculation_1005]' />
      </column>
      <column caption='Income Tier' datatype='string' name='[Calculation_1007]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [MedInc] &gt;= 6 THEN &quot;High&quot; ELSEIF [MedInc] &gt;= 3 THEN &quot;Mid&quot; ELSE &quot;Low&quot; END' />
      </column>
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <semantic-values>
        <semantic-value key='[Country].[Name]' value='&quot;United Kingdom&quot;' />
      </semantic-values>
      <date-options start-of-week='monday' />

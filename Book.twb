            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <tooltip column='[federated.hist01].[avg:value_bin_mid:qk]' />
              <tooltip column='[federated.hist01].[sum:count:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.hist01].[sum:count:qk]</rows>
        <cols>[federated.hist01].[none:bin_index:ok]</cols>
      </table>
      <simple-id uuid='{C0000008-0000-0000-0000-000000000008}' />
    </worksheet>
    <worksheet name='Med house value heat map'>
      <table>
        <view>
          <datasources>
            <datasource caption='Housing geographic (heatmap)' name='federated.geo01' />
          </datasources>
          <datasource-dependencies datasource='federated.geo01'>
            <column caption='Latitude' datatype='real' default-format='#0.00' name='[Latitude]' role='measure' type='quantitative' />
            <column caption='Longitude' datatype='real' default-format='#0.00' name='[Longitude]' role='measure' type='quantitative' />
            <column caption='MedHouseVal' datatype='real' default-format='#,##0.00' name='[MedHouseVal]' role='measure' type='quantitative' />
            <column datatype='real' default-format='#0.0%' name='[MedHouseVal_pct]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='false' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Circle' />
            <encodings>
              <color column='[federated.geo01].[MedHouseVal_pct]' />
              <tooltip column='[federated.geo01].[MedHouseVal]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.geo01].[Latitude]</rows>
        <cols>[federated.geo01].[Longitude]</cols>
      </table>
      <simple-id uuid='{C0000005-0000-0000-0000-000000000005}' />
    </worksheet>

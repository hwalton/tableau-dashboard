            </encodings>
          </pane>
        </panes>
        <rows>[federated.ratio01].[sum:count:qk]</rows>
        <cols>([federated.ratio01].[none:Feature:nk] / [federated.ratio01].[none:bin_index:ok])</cols>
      </table>

    </worksheet>
    <worksheet name='Ratio scatter'>
      <table>
        <view>
          <datasources>
            <datasource caption='Ratio scatter (bedrooms_ratio vs MedHouseVal)' name='federated.scat01' />
          </datasources>
          <datasource-dependencies datasource='federated.scat01'>
            <column caption='Bedrooms ratio' datatype='real' default-format='#,##0.000' name='[bedrooms_ratio]' role='measure' type='quantitative' />
            <column caption='Med House Val' datatype='real' default-format='#,##0.00' name='[MedHouseVal]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='false' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Circle' />
          </pane>
        </panes>
        <rows>[federated.scat01].[MedHouseVal]</rows>
        <cols>[federated.scat01].[bedrooms_ratio]</cols>
      </table>

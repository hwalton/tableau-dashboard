  <worksheets>
    <worksheet name='Data preview (head)'>
      <table>
        <view>
          <datasources>
            <datasource caption='Housing head (preview)' name='federated.head01' />
          </datasources>
          <datasource-dependencies datasource='federated.head01'>
            <column caption='Row id' datatype='integer' name='[row_id]' role='dimension' type='ordinal' />
            <column caption='Measure' datatype='string' name='[measure]' role='dimension' type='nominal' />
            <column datatype='real' default-format='#,##0.######' name='[value]' role='measure' type='quantitative' />
            <column-instance column='[row_id]' derivation='None' name='[none:row_id:ok]' pivot='key' type='ordinal' />
            <column-instance column='[measure]' derivation='None' name='[none:measure:nk]' pivot='key' type='nominal' />
            <column-instance column='[value]' derivation='Sum' name='[sum:value:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Text' />
            <encodings>
              <text column='[federated.head01].[sum:value:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.head01].[none:row_id:ok]</rows>
        <cols>[federated.head01].[none:measure:nk]</cols>
      </table>
      <simple-id uuid='{C0000001-0000-0000-0000-000000000001}' />
    </worksheet>
    <worksheet name='Describe table'>
      <table>
        <view>
          <datasources>
            <datasource caption='Feature stats (describe)' name='federated.cells_stats01' />
          </datasources>
          <datasource-dependencies datasource='federated.cells_stats01'>
            <column datatype='string' name='[Feature]' role='dimension' type='nominal' />
            <column caption='Stat rank' datatype='integer' name='[stat_rank]' role='dimension' type='ordinal' />
            <column datatype='string' name='[stat]' role='dimension' type='nominal' />
            <column datatype='string' name='[cell]' role='dimension' type='nominal' />
            <column-instance column='[Feature]' derivation='None' name='[none:Feature:nk]' pivot='key' type='nominal' />
            <column-instance column='[stat_rank]' derivation='None' name='[none:stat_rank:ok]' pivot='key' type='ordinal' />
            <column-instance column='[stat]' derivation='None' name='[none:stat:nk]' pivot='key' type='nominal' />
            <column-instance column='[cell]' derivation='Attribute' name='[attr:cell:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Text' />
            <encodings>
              <text column='[federated.cells_stats01].[attr:cell:nk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.cells_stats01].[none:Feature:nk]</rows>
        <cols>([federated.cells_stats01].[none:stat_rank:ok] / [federated.cells_stats01].[none:stat:nk])</cols>
      </table>
      <simple-id uuid='{C0000003-0000-0000-0000-000000000003}' />
    </worksheet>
    <worksheet name='MedHouseVal histogram'>
      <table>
        <view>
          <datasources>
            <datasource caption='MedHouseVal histogram (binned)' name='federated.hist01' />
          </datasources>
          <datasource-dependencies datasource='federated.hist01'>
            <column caption='Bin index' datatype='integer' name='[bin_index]' role='dimension' type='ordinal' />
            <column caption='Value bin midpoint' datatype='real' default-format='#,##0.00' name='[value_bin_mid]' role='measure' type='quantitative' />
            <column datatype='integer' name='[count]' role='measure' type='quantitative' />
            <column-instance column='[bin_index]' derivation='None' name='[none:bin_index:ok]' pivot='key' type='ordinal' />
            <column-instance column='[value_bin_mid]' derivation='Avg' name='[avg:value_bin_mid:qk]' pivot='key' type='quantitative' />
            <column-instance column='[count]' derivation='Sum' name='[sum:count:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>

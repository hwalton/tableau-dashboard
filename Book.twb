            <column-instance column='[Feature]' derivation='None' name='[none:Feature:nk]' pivot='key' type='nominal' />
            <column-instance column='[bin_index]' derivation='None' name='[none:bin_index:ok]' pivot='key' type='ordinal' />
            <column-instance column='[value_bin_mid]' derivation='Avg' name='[avg:value_bin_mid:qk]' pivot='key' type='quantitative' />
            <column-instance column='[count]' derivation='Sum' name='[sum:count:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>

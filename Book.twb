    <worksheet name='Ratio features'>
      <table>
        <view>
          <datasources>
            <datasource caption='Ratio features (bedrooms_ratio histogram)' name='federated.ratio01' />
          </datasources>
          <datasource-dependencies datasource='federated.ratio01'>
